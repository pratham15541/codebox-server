PORT=8000
JWT_SECRET=your-jwt-secret

# Option A: full connection string (URL-encode special chars in password)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/codebox?retryWrites=true&w=majority

# Option B: split vars (password is auto URL-encoded — use if password has @ # : / etc.)
# MONGODB_USER=your-user
# MONGODB_PASSWORD=your-password
# MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net
# MONGODB_DB=codebox

NODEMAILER_SERVICE=gmail
NODEMAILER_AUTH_USER=
NODEMAILER_AUTH_PASS=

PINECONE_API_KEY=
PINECONE_INDEX=codebox-code-chunks
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

AI_API_KEY=
AI_MODEL=nvidia/nemotron-3-super-120b-a12b
AI_BASE_URL=https://integrate.api.nvidia.com/v1
EMBEDDING_MODEL=nvidia/nv-embed-v1
EMBEDDING_DIMENSION=1024

CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=6
RERANK_TOP_K=4
